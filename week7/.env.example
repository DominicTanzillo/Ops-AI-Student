# Copy to .env and fill in your values. .env is gitignored.
#
# REQUIRED for live Gemini demo runs (cost-gated; not needed for tests):
#   Get a free Google AI Studio key at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# OPTIONAL - default is in-memory storage (recommended for dev + tests).
# Set to 'firestore' only when you have GCP credentials and want
# production-shape persistence. Costs apply.
STORAGE_BACKEND=memory

# OPTIONAL - Firestore project (only used when STORAGE_BACKEND=firestore)
GCP_PROJECT_ID=

# OPTIONAL - SQLite database path; defaults to data/techcorp.db
TECHCORP_DB_PATH=data/techcorp.db

# OPTIONAL - Multi-shot agent iteration cap. Default 5.
AGENT_MAX_ITERATIONS=5
